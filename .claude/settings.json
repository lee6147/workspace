{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "language": "korean",
  "outputStyle": "Intermediate Developer",
  "permissions": {
    "allow": [
      "Bash(gh auth:*)",
      "Bash(gh repo:*)",
      "Bash(gh api:*)",
      "Bash(npm run lint)",
      "Bash(npm run test *)",
      "Bash(npm run build)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ]
  }
}
