{
  "permissions": {
    "allow": [
      "WebFetch(domain:www.npmjs.com)",
      "WebSearch",
      "Bash(npm install:*)",
      "Bash(npx shadcn@latest:*)",
      "Bash(npm run:*)",
      "Bash(rm:*)",
      "Bash(npm uninstall:*)",
      "Bash(npx next:*)",
      "Bash(npm test:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo \" Test hook!\" >> ./hook-test.txt"
          }
        ]
      }
    ]
  }
}
